// Touch swipe
function setupSwipe() {
  const wrap = document.getElementById('swipe-wrap');
  let startX = 0, startY = 0, isDragging = false;
  wrap.addEventListener('touchstart', e => { startX=e.touches[0].clientX; startY=e.touches[0].clientY; isDragging=true; }, {passive:true});
  wrap.addEventListener('touchend', e => {
    if (!isDragging) return; isDragging=false;
    const dx = e.changedTouches[0].clientX - startX;
    const dy = e.changedTouches[0].clientY - startY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      goCard(dx < 0 ? 1 : -1);
    }
  }, {passive:true});
}
 
function upSet(ei,si,f,v) { S.activeExercises[ei].sets[si][f]=v; }
 
function togSet(ei,si) {
  const set = S.activeExercises[ei].sets[si];
  set.done = !set.done;
  renderCards();
  // Auto-advance if all sets done on current exercise
  const ex = S.activeExercises[ei];
  if (ex.sets.every(s=>s.done) && S.currentCard === ei && ei < S.activeExercises.length-1) {
    setTimeout(()=>goCard(1), 600);
  }
}
 
function addSet(ei) { S.activeExercises[ei].sets.push({w:'',r:'',done:false}); renderCards(); }
 
function finishWorkout() {
  if (!S.activeWorkout) return;
  clearInterval(S.timerIv);
  const dur = S.timerStart ? Math.floor((Date.now()-S.timerStart-S.pauseAccum)/60000) : 0;
  const exs = S.activeExercises.map(ex => {
    const done = ex.sets.filter(s=>s.done);
    let isPR=false;
    done.forEach(s=>{
      const w=parseFloat(s.w)||0, r=parseInt(s.r)||0;
      if(w>0&&(!S.prs[ex.name]||w>S.prs[ex.name].w)){S.prs[ex.name]={w,r,date:new Date().toLocaleDateString('en-NZ',{day:'numeric',month:'short',year:'numeric'})};isPR=true;}
    });
    return {name:ex.name,muscle:ex.muscle,sets:done.length,isPR};
  });
  S.history.unshift({name:S.activeWorkout.name,tag:S.activeWorkout.tag,
    date:new Date().toLocaleDateString('en-NZ',{weekday:'short',day:'numeric',month:'short',year:'numeric'}),
    ts:Date.now(),duration:dur,exercises:exs,totalSets:exs.reduce((a,e)=>a+e.sets,0)});
  S.activeWorkout=null; S.activeExercises=[]; S.timerStart=null; S.pauseAccum=0;
  save(); renderDash();
  showScreen('dash', document.querySelectorAll('.nav-btn')[0]);
}
