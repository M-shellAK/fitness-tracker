    const mn=Math.min(...pts)*.92,mx2=Math.max(...pts)*1.05;
    const W=300,H=44,pad=4;
    const xs=pts.map((_,i)=>pad+(i/(pts.length-1))*(W-pad*2));
    const ys=pts.map(v=>H-pad-((v-mn)/(mx2-mn||1))*(H-pad*2));
    const path=xs.map((x,i)=>(i===0?'M':'L')+x.toFixed(1)+','+ys[i].toFixed(1)).join(' ');
    return`<div class="spark-card"><div class="spark-hd"><div class="spark-nm">${name}</div><div><div class="spark-pr">${pr.w}kg</div><div class="spark-pr-lbl">CURRENT PR</div></div></div><svg class="spark" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none"><path d="${path}" stroke="var(--red)" stroke-width="2" fill="none" stroke-linejoin="round"/>${xs.map((x,i)=>`<circle cx="${x.toFixed(1)}" cy="${ys[i].toFixed(1)}" r="3" fill="var(--red)" opacity=".7"/>`).join('')}</svg></div>`;
  }).join('');
}
 
